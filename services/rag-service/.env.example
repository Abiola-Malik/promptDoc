# Gemini
GEMINI_API_KEY=

# Voyage AI (query embedding — must match embed-service model)
VOYAGE_API_KEY=

# Pinecone
PINECONE_API_KEY=
PINECONE_INDEX_NAME=promptdoc
PINECONE_HOST=

# Internal auth
INTERNAL_API_SECRET=

# RAG config
MAX_RETRIEVAL_RESULTS=8    # results per query
MAX_CONTEXT_CHUNKS=12      # max chunks fed to Gemini after dedup
MAX_CRITIQUE_LOOPS=1      # max refine iterations for doc gen
TEMPERATURE=0.2            # lower = more factual, higher = more creative

# LangSmith config
LANGSMITH_API_KEY=
LANGCHAIN_TRACING=true
LANGSMITH_PROJECT=promptdoc-rag
LANGSMITH_ENDPOINT=https://api.smith.langchain.com