# ── web/.env.local ──────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
APPWRITE_PROJECT_ID=
APPWRITE_API_KEY=
NEXT_PUBLIC_APPWRITE_ENDPOINT=

# URLs pointing at Python services (localhost in dev, Railway URLs in prod)
CHUNK_SERVICE_URL=http://localhost:8001
EMBED_SERVICE_URL=http://localhost:8002
RAG_SERVICE_URL=http://localhost:8003

# Shared secret so Python services can verify requests came from your BFF
INTERNAL_API_SECRET=

# ── services/chunk-service/.env ─────────────────────
INTERNAL_API_SECRET=         # same value as above
REDIS_URL=redis://redis:6379 # service name in Docker network

# ── services/embed-service/.env ─────────────────────
INTERNAL_API_SECRET=
REDIS_URL=redis://redis:6379
GEMINI_API_KEY=
PINECONE_API_KEY=
PINECONE_INDEX_NAME=
APPWRITE_PROJECT_ID=         # for writing job status back
APPWRITE_API_KEY=

# ── services/rag-service/.env ───────────────────────
INTERNAL_API_SECRET=
GEMINI_API_KEY=
PINECONE_API_KEY=
PINECONE_INDEX_NAME=